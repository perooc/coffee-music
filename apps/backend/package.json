{
  "name": "@coffee-bar/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "nest start --watch",
    "start:dev": "nest start --watch",
    "// start:prod": "Used by Railway. Runs DB migrations against the live cluster, then boots the compiled app.",
    "start:prod": "prisma migrate deploy && node dist/main.js",
    "// db:import-products": "One-shot import from a CSV/XLSX of products. Pass the file path as argv: `npm run db:import-products -- ./products.xlsx`.",
    "db:import-products": "tsx prisma/import-products.ts",
    "// db:ensure-tables": "Idempotent: makes sure all numbered tables exist. Safe in production.",
    "db:ensure-tables": "tsx prisma/ensure-tables.ts",
    "// qr:tokens": "Print tokens + URLs and (optionally) write JSON. Set QR_BASE_URL=https://crown490.com.",
    "qr:tokens": "tsx prisma/print-table-tokens.ts",
    "// qr:generate": "Render PNG QR codes from the JSON produced by qr:tokens.",
    "qr:generate": "tsx prisma/generate-qrs.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@coffee-bar/shared": "*",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/mapped-types": "^2.1.1",
    "@nestjs/platform-express": "^11.1.6",
    "@nestjs/platform-socket.io": "^11.1.6",
    "@nestjs/websockets": "^11.1.6",
    "@prisma/client": "^6.7.0",
    "@sentry/nestjs": "^10.51.0",
    "@sentry/profiling-node": "^10.51.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ytsr": "^3.8.4"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.10",
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.7.2",
    "@types/qrcode": "^1.5.6",
    "jsonwebtoken": "^9.0.2",
    "prisma": "^6.7.0",
    "qrcode": "^1.5.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "xlsx": "^0.18.5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
