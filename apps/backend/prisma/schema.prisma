generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TableStatus {
  available
  occupied
  closing
}

enum TableSessionStatus {
  open
  ordering
  closing
  closed
}

enum QueueStatus {
  pending
  playing
  played
  skipped
}

enum QueueItemSource {
  customer
  house
}

enum OrderRequestStatus {
  pending
  accepted
  rejected
  cancelled
}

enum OrderStatus {
  accepted
  preparing
  ready
  delivered
  cancelled
}

enum ConsumptionType {
  product
  adjustment
  discount
  refund
}

enum PlaybackStatus {
  idle
  buffering
  playing
  paused
}

enum UserRole {
  admin
  staff
}

enum InventoryMovementType {
  restock
  adjustment
  waste
  correction
}

model User {
  id            Int      @id @default(autoincrement())
  name          String
  email         String   @unique
  password_hash String
  role          UserRole @default(staff)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt
}

model Table {
  id                     Int            @id @default(autoincrement())
  number                 Int            @unique
  qr_code                String         @unique
  status                 TableStatus    @default(available)
  current_session_id     Int?           @unique
  total_consumption      Decimal        @default(0) @db.Decimal(10, 2)
  active_order_count     Int            @default(0)
  pending_request_count  Int            @default(0)
  last_activity_at       DateTime?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt
  songs                  Song[]
  queue_items            QueueItem[]
  sessions               TableSession[] @relation("TableSessions")
  current_session        TableSession?  @relation("TableCurrentSession", fields: [current_session_id], references: [id], onDelete: SetNull)
}

model TableSession {
  id                  Int                @id @default(autoincrement())
  table_id            Int
  status              TableSessionStatus @default(open)
  total_consumption   Decimal            @default(0) @db.Decimal(10, 2)
  last_consumption_at DateTime?
  opened_at           DateTime           @default(now())
  closed_at           DateTime?
  // Customer-driven flag: "I want the bill". When set, no new
  // OrderRequest can be created for this session until cleared. The session
  // stays `open` and the music/fairness signals are unaffected.
  payment_requested_at DateTime?
  // Admin-driven flag: payment processed. Stays open after this — the
  // table can keep consuming; new orders are still blocked until close.
  // We deliberately keep this as a single timestamp instead of a Payment
  // table because the read model never needs partial-payment math.
  paid_at             DateTime?
  metadata            Json?
  created_at          DateTime           @default(now())
  updated_at          DateTime           @updatedAt
  table               Table              @relation("TableSessions", fields: [table_id], references: [id], onDelete: Cascade)
  current_of_table    Table?             @relation("TableCurrentSession")
  order_requests      OrderRequest[]
  orders              Order[]
  consumptions        Consumption[]

  @@index([table_id, status])
  @@index([status])
}

model Song {
  id                 Int         @id @default(autoincrement())
  youtube_id         String      @unique
  title              String
  duration           Int
  requested_by_table Int?
  created_at         DateTime    @default(now())
  table              Table?      @relation(fields: [requested_by_table], references: [id], onDelete: Cascade)
  queue_items        QueueItem[]
}

model QueueItem {
  id                 Int            @id @default(autoincrement())
  song_id            Int
  table_id           Int?
  priority_score     Decimal        @default(0) @db.Decimal(10, 2)
  status             QueueStatus    @default(pending)
  position           Int
  queued_at          DateTime       @default(now())
  created_at         DateTime       @default(now())
  updated_at         DateTime       @updatedAt
  started_playing_at DateTime?
  finished_at        DateTime?
  skipped_at         DateTime?
  // True when this song was queued as the table's 6th, 7th, ... slot —
  // i.e. when there were already MAX_SONGS_PER_TABLE active items at the
  // moment of insertion. Each "extra" song consumes one credit earned by
  // a delivered order >= EXTRA_SONG_CONSUMPTION_THRESHOLD. If admin skips
  // an extra song, its is_extra flag stays true but the credit-spent
  // count excludes `skipped`, so the credit is effectively returned.
  is_extra           Boolean        @default(false)
  // Where this queue item came from. `customer` = a real table queued it
  // through the QR. `house` = the bar-curated playlist auto-fills the
  // queue when no customer songs are pending. House items always have
  // table_id = null and priority_score = 0.
  source             QueueItemSource @default(customer)
  song               Song           @relation(fields: [song_id], references: [id], onDelete: Cascade)
  table              Table?         @relation(fields: [table_id], references: [id], onDelete: Cascade)
  playback_state     PlaybackState?

  @@index([status, position])
  @@index([table_id, status])
  @@index([status, source, position])
}

/**
 * Bar-curated fallback playlist. Loaded one item at a time into the live
 * QueueItem stream when there's no customer music in the queue. Edited
 * only by admin via /admin/musica-base.
 */
model HousePlaylistItem {
  id             Int       @id @default(autoincrement())
  youtube_id     String    @unique
  title          String
  // Optional — the YouTube validation endpoint may or may not return it.
  artist         String?
  duration       Int
  is_active      Boolean   @default(true)
  sort_order     Int       @default(0)
  last_played_at DateTime?
  created_at     DateTime  @default(now())
  updated_at     DateTime  @updatedAt

  @@index([is_active, sort_order])
  @@index([is_active, last_played_at])
}

model Product {
  id                    Int                  @id @default(autoincrement())
  name                  String
  description           String?
  price                 Decimal              @db.Decimal(10, 2)
  stock                 Int                  @default(0)
  // Threshold below which the admin UI flags the product as "low stock".
  // 0 = no warning. Operational hint, not enforced anywhere.
  low_stock_threshold   Int                  @default(0)
  is_active             Boolean              @default(true)
  category              String
  created_at            DateTime             @default(now())
  updated_at            DateTime             @updatedAt
  order_items           OrderItem[]
  inventory_movements   InventoryMovement[]
}

/**
 * Audit-grade record of every manual change to Product.stock that was not
 * caused by an order accept/cancel. Sales (accept lowering stock) and
 * cancellations (refunding stock) are NOT InventoryMovement rows: those are
 * already tracked by Order/OrderItem and do not duplicate here. This table
 * answers the question "why did stock change *outside* of customer flow?".
 */
model InventoryMovement {
  id          Int                   @id @default(autoincrement())
  product_id  Int
  type        InventoryMovementType
  // Signed delta applied to Product.stock at the moment of recording. The
  // service layer enforces sign rules per type (restock > 0, waste < 0,
  // adjustment/correction free).
  quantity    Int
  reason      String?
  notes       String?
  created_by  String?
  created_at  DateTime              @default(now())
  product     Product               @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id, created_at])
  @@index([type, created_at])
}

model OrderRequest {
  id                Int                @id @default(autoincrement())
  table_session_id  Int
  status            OrderRequestStatus @default(pending)
  items             Json
  rejection_reason  String?
  created_at        DateTime           @default(now())
  updated_at        DateTime           @updatedAt
  accepted_at       DateTime?
  rejected_at       DateTime?
  cancelled_at      DateTime?
  table_session     TableSession       @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  order             Order?

  @@index([table_session_id, status])
  @@index([status])
}

model Order {
  id                Int          @id @default(autoincrement())
  table_session_id  Int
  order_request_id  Int          @unique
  status            OrderStatus  @default(accepted)
  accepted_at       DateTime     @default(now())
  delivered_at      DateTime?
  cancelled_at      DateTime?
  created_at        DateTime     @default(now())
  updated_at        DateTime     @updatedAt
  table_session     TableSession @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  order_request     OrderRequest @relation(fields: [order_request_id], references: [id], onDelete: Restrict)
  order_items       OrderItem[]
  consumptions      Consumption[]

  @@index([table_session_id, status])
  @@index([status])
}

model OrderItem {
  id         Int      @id @default(autoincrement())
  order_id   Int
  product_id Int
  quantity   Int
  unit_price Decimal  @db.Decimal(10, 2)
  created_at DateTime @default(now())
  order      Order    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Restrict)

  @@index([order_id])
  @@index([product_id])
}

model Consumption {
  id                Int             @id @default(autoincrement())
  table_session_id  Int
  order_id          Int?
  product_id        Int?
  description       String
  quantity          Int             @default(1)
  unit_amount       Decimal         @db.Decimal(10, 2)
  amount            Decimal         @db.Decimal(10, 2)
  type              ConsumptionType @default(product)
  reversed_at       DateTime?
  reverses_id       Int?            @unique
  reason            String?
  notes             String?
  created_by        String?
  created_at        DateTime        @default(now())
  table_session     TableSession    @relation(fields: [table_session_id], references: [id], onDelete: Cascade)
  order             Order?          @relation(fields: [order_id], references: [id], onDelete: SetNull)
  reverses          Consumption?    @relation("ConsumptionReversal", fields: [reverses_id], references: [id], onDelete: SetNull)
  reversal          Consumption?    @relation("ConsumptionReversal")

  @@index([table_session_id, created_at])
  @@index([order_id])
}

model PlaybackState {
  id               Int            @id @default(autoincrement())
  status           PlaybackStatus @default(idle)
  queue_item_id    Int?           @unique
  started_at       DateTime?
  position_seconds Int?
  created_at       DateTime       @default(now())
  updated_at       DateTime       @updatedAt
  queue_item       QueueItem?     @relation(fields: [queue_item_id], references: [id], onDelete: SetNull)
}
