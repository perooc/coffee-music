# ════════════════════════════════════════════════════════════════════════
#  FRONTEND  (apps/frontend/.env.local in dev, Vercel env vars in prod)
# ════════════════════════════════════════════════════════════════════════
# Public API base URL — must include `/api` suffix
#   dev:  http://localhost:3001/api
#   prod: https://<your-railway-service>.up.railway.app/api
NEXT_PUBLIC_API_URL=

# Socket.IO URL — same host as API but WITHOUT the /api suffix
#   dev:  http://localhost:3001
#   prod: https://<your-railway-service>.up.railway.app
NEXT_PUBLIC_SOCKET_URL=

# ════════════════════════════════════════════════════════════════════════
#  BACKEND  (apps/backend/.env in dev, Railway env vars in prod)
# ════════════════════════════════════════════════════════════════════════
PORT=3001

# Postgres connection string. Railway gives you DATABASE_URL automatically
# when you add the Postgres plugin; copy that value directly.
DATABASE_URL=

# JWT secret — MUST be a long random string in production. Rotate this
# value on the day of launch and never commit the real one.
JWT_SECRET=
JWT_ADMIN_EXPIRES_IN=12h
JWT_SESSION_EXPIRES_IN=6h

# Used only by `npx prisma db seed`. Pick a strong password and change it
# from the admin UI right after the first login.
SEED_ADMIN_EMAIL=admin@cafe.local
SEED_ADMIN_PASSWORD=

# YouTube Data API v3 keys. The hybrid provider walks them in order:
#   YOUTUBE_API_KEY    → primary
#   YOUTUBE_API_KEY_2  → fallback (when key 1's daily 10k budget runs out
#                                  or the key 403s for any reason)
#   YOUTUBE_API_KEY_3  → tertiary (rarely needed)
# Each key has its own per-day budget tracker. After all keys, the system
# falls back to ytsr (no key needed). Pull keys from console.cloud.google.com.
YOUTUBE_API_KEY=
YOUTUBE_API_KEY_2=
# Optional: stop hitting an individual YouTube key once daily quota crosses
# this soft limit (default 8000 of the free 10k units). Applies per key.
YOUTUBE_DAILY_BUDGET_SOFT_LIMIT=8000
SEARCH_CACHE_TTL_SECONDS=1800

# Public table picker (temporary, while QR codes aren't printed).
# Set ALLOW_PUBLIC_TABLE_TOKENS=false to disable the public landing entirely.
ALLOW_PUBLIC_TABLE_TOKENS=true
# The code customers must type on the landing. Pick something easy to
# write on a chalkboard but not trivial to guess. Rotate periodically.
BAR_ACCESS_CODE=

# Origin(s) allowed to call the API. In production this MUST be set to
# your frontend domain (e.g. https://crown490.com). Comma-separate to
# allow multiple. The backend reads `FRONTEND_URLS` first, falls back to
# `FRONTEND_URL`, then to localhost:3000.
FRONTEND_URLS=http://localhost:3000
